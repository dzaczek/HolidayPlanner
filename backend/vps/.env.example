# Copy this file to .env and fill in your values
# cp .env.example .env

# Port to listen on
PORT=3000

# Path to SQLite database file (inside the Docker volume)
DB_PATH=/data/hcp.db

# Max allowed blob size in bytes (default: 524288 = 512 KB)
MAX_BLOB_BYTES=524288

# CORS allowed origins (* = all, or specify your domain)
CORS_ORIGIN=*
