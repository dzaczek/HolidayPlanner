# Cloudflare Tunnel token
# Get from: https://one.dash.cloudflare.com → Zero Trust → Networks → Tunnels → Create
# Configure tunnel to point to http://hcp:8080
CF_TUNNEL_TOKEN=your-tunnel-token-here

# HCP Sync client token — must match the HCP_CLIENT_TOKEN secret set in CF Worker
# Generate a random token: openssl rand -base64 32
# Then: wrangler secret put HCP_CLIENT_TOKEN
VITE_HCP_CLIENT_TOKEN=your-random-token-here
